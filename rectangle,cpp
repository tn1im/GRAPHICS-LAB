#include <GL/glut.h>

void display() {
    // Clear the screen
    glClear(GL_COLOR_BUFFER_BIT);

    // Draw the Rectangle (Quad)
    glBegin(GL_QUADS);
    glColor3f(0.5f, 0.0f, 0.5f); // Purple color

    // Define 4 corners in order (Clockwise or Counter-Clockwise)
    glVertex2f(-0.7f, 0.4f); // Top Left
    glVertex2f(0.7f, 0.4f); // Top Right
    glVertex2f(0.7f, -0.4f); // Bottom Right
    glVertex2f(-0.7f, -0.4f); // Bottom Left
    glEnd();

    glFlush();
}

int main(int argc, char** argv) {
    glutInit(&argc, argv);
    glutInitWindowSize(600, 600);
    glutCreateWindow("OpenGL Rectangle Project");
    glutDisplayFunc(display);
    glutMainLoop();
    return 0;
}
